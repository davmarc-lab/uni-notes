\usepackage{textcomp}
\usepackage[most]{tcolorbox}
\tcbuselibrary{listings, breakable, skins}

\lstalias{py}{Python}
\lstalias{cpp}{C++}

% shorthand command for the prompt to save typing
\newcommand{\prompt}{\textcolor{green}{user@linux:~\$} }
\newcommand{\rootprompt}{\textcolor{red}{root@linux:~\$} }

\newtcblisting{terminal}[1]{
    enhanced,
    listing only,
    breakable,
    colback=black!95,
    colframe=gray!70,
    colupper=white,
    arc=6pt,
    boxrule=1pt,
    code={\ifstrempty{#1}{}{\tcbset{title={\small\ttfamily #1}}}},
    fonttitle=\bfseries\ttfamily,
    coltitle=white,
    left=5pt,
    listing options={
        language=bash,
        basicstyle=\ttfamily\small\color{white},
        upquote=true,
        breaklines=true,
        showstringspaces=false,
        escapeinside={(*}{*)},      % 'escape' characters to use latex commands
        keywordstyle=\color{cyan},
        commentstyle=\color{gray!60},
        stringstyle=\color{orange}
    }
}

\newtcblisting{codeblock}[2][bash]{
    enhanced,
    listing only,
    breakable,
    colback=code-bg,
    colframe=gh-gray-border,
    arc=6pt,
    boxrule=0.5pt,
    top=10pt,
    bottom=10pt,
    left=10pt,
    listing options={
        language=#1,
        basicstyle=\ttfamily\small,
        upquote=true,
        keywordstyle=\color{blue},
        commentstyle=\color{gray},
        stringstyle=\color{orange},
        breaklines=true,
        showstringspaces=false,
        tabsize=2,
    },
    title={#2},
    coltitle=black,
    attach boxed title to top left={yshift=-2mm, xshift=5mm},
    boxed title style={colback=white, colframe=gh-gray-border, sharp corners, boxrule=0.5pt}
}

% --- Command to include external files ---
\newcommand{\codefile}[3][bash]{
    \tcbinputlisting{
        enhanced,
        listing file={#3},
        listing only,
        breakable,
        colback=code-bg,
        colframe=gh-gray-border,
        arc=6pt,
        boxrule=0.5pt,
        top=10pt,
        bottom=10pt,
        left=10pt,
        listing options={
            language=#1,
            upquote=true,
            basicstyle=\ttfamily\small,
            keywordstyle=\color{blue},
            commentstyle=\color{gray},
            stringstyle=\color{orange},
            breaklines=true,
            showstringspaces=false,
            tabsize=2,
        },
        title={#2},
        coltitle=black,
        attach boxed title to top left={yshift=-2mm, xshift=5mm},
        boxed title style={colback=white, colframe=gh-gray-border, sharp corners, boxrule=0.5pt}
    }
}

