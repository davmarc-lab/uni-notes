\newtcbtheorem[number within=section, list inside=def]{definition}{Definizione}{
    enhanced, breakable,
    halign=left,
    colback=gh-purple-bg,
    colframe=gh-purple,
    fonttitle=\bfseries,
    coltitle=gh-purple,
    attach title to upper,
    after title={\enspace---\enspace},
    boxrule=0.5pt,
    arc=2pt,
    description font=\itshape,
    label type=definition,
    after=\noindent\ignorespacesafterend
}{def}

\newtcbtheorem[number within=section, list inside=th]{theorem}{Teorema}{
    enhanced, breakable,
    halign=left,
    colback=gh-red-bg,
    colframe=gh-red,
    fonttitle=\bfseries,
    coltitle=white,
    colbacktitle=gh-red,
    boxed title style={sharp corners, size=small},
    arc=2pt,
    separator sign={:},
    label type=theorem,
    after=\noindent\ignorespacesafterend
}{th}

\renewcommand{\qedsymbol}{\textcolor{gh-red}{\ensuremath{\blacksquare}}}
\newtcolorbox{proofbox}[1][Proof]{
    enhanced,
    breakable,
    halign=left,
    colback=gh-red-bg!95!gh-red,
    colframe=gh-red,
    attach title to upper,
    fonttitle=\bfseries\itshape,
    coltitle=gh-red,
    title={#1:\upshape\enspace},
    boxrule=0.5pt,
    arc=2pt,
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    separator sign none,
    before skip=10pt,
    after skip=15pt,
    underlay={
        \node[anchor=south east, outer sep=5pt] at (frame.south east) {\qedsymbol};
    },
    label type=proof,
    after=\noindent\ignorespacesafterend
}
\renewenvironment{proof}[1][Dimostrazione]{\begin{proofbox}[#1]}{\end{proofbox}}

\newtcbtheorem[number within=section]{outerproof}{Dimostrazione}{
    enhanced,
    breakable,
    halign=left,
    colback=gh-red-bg,
    colframe=gh-red,
    fonttitle=\bfseries\itshape,
    coltitle=gh-red,
    attach title to upper,
    after title={:\enspace}, 
    boxrule=0.5pt,
    arc=2pt,
    description font=\normalfont,
    separator sign none,
    underlay={
        \node[anchor=south east, outer sep=6pt] at (frame.south east) {\qedsymbol};
    },
    label type=proof,
    after=\noindent\ignorespacesafterend
}{prf}
\newenvironment{proofblock}[1]{\begin{outerproof}{}{#1}}{\end{outerproof}}

