\renewcommand{\tt}[1]{\texttt{#1}}

\newcommand{\emptyln}{\newline{}\newline{}}

% Math shortcuts

% --- Parentheses ---
\newcommand{\ab}[1]{\left | {#1} \right |}
\newcommand{\nm}[1]{\left\|{#1}\right\|}

\newcommand{\pt}[1]{\left({#1}\right)}
\newcommand{\ps}[1]{\left[{#1}\right]}
\newcommand{\pg}[1]{\left\{{#1}\right\}}

% --- Symbols ---

\newcommand{\lw}[2][]{{#2}_{#1}}
\newcommand{\hg}[2][]{{#2}^{#1}}

\newcommand{\alo}{\lw[0]{a}}
\newcommand{\ali}{\lw[1]{a}}
\newcommand{\alii}{\lw[2]{a}}
\newcommand{\aln}{\lw[n]{a}}

\newcommand{\blo}{\lw[0]{b}}
\newcommand{\bli}{\lw[1]{b}}
\newcommand{\blii}{\lw[2]{b}}
\newcommand{\bln}{\lw[n]{b}}

\newcommand{\qlo}{\lw[0]{q}}
\newcommand{\qli}{\lw[1]{q}}
\newcommand{\qlii}{\lw[2]{q}}
\newcommand{\qln}{\lw[n]{q}}

% --- Greek Letters ---
\newcommand{\power}[2]{{#1}^{#2}}

\newcommand{\al}[1][]{\power{\alpha}{#1}}
\newcommand{\Al}[1][]{\power{\Alpha}{#1}}
\newcommand{\dt}[1][]{\power{\delta}{#1}}
\newcommand{\Dt}[1][]{\power{\Delta}{#1}}
\newcommand{\eps}[1][]{\power{\epsilon}{#1}}
\newcommand{\Eps}[1][]{\power{\Epsilon}{#1}}
\newcommand{\si}[1][]{\power{\sigma}{#1}}
\newcommand{\Si}[1][]{\power{\Sigma}{#1}}
\newcommand{\om}[1][]{\power{\omega}{#1}}
\newcommand{\Om}[1][]{\power{\Omega}{#1}}

\newcommand{\hdt}[1][]{\hat{\power{\delta}{#1}}}

