\usepackage[most]{tcolorbox}
\usepackage{colors}

% Parameters: #1 (Color), #2 (Background), #3 (Title text)
\newtcolorbox{callout}[4]{
    enhanced,
    breakable,
    sharp corners,
    boxrule=0pt,
    leftrule=3pt,
    colframe=#1,
    colback=#2,
    fonttitle=\bfseries,
    coltitle=#1,
    % Title logic: Bold Main Title + Italic Sub-title in parentheses
    title={#3:\enspace\ifstrempty{#4}{}\textnormal{\textit{#4}}}, 
    attach title to upper,
    after title={\ifstrempty{#4}{}{\newline}},
    left=10pt,
    right=10pt,
    top=5pt,
    bottom=5pt,
}

\newenvironment{note}[1][]{\begin{callout}{gh-blue}{gh-blue-bg}{Note}{#1}}{\end{callout}}

\newenvironment{tip}[1][]{\begin{callout}{gh-green}{gh-green-bg}{Tip}{#1}}{\end{callout}}

\newenvironment{warning}[1][]{\begin{callout}{gh-orange}{gh-orange-bg}{Warning}{#1}}{\end{callout}}

\newenvironment{critical}[1][]{\begin{callout}{gh-red}{gh-red-bg}{Critical}{#1}}{\end{callout}}

